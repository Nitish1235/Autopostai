{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": false,
        "declarationMap": false,
        "sourceMap": false,
        "moduleResolution": "node",
        "paths": {
            "@/*": [
                "./*"
            ]
        },
        "baseUrl": ".",
        "jsx": "react-jsx"
    },
    "include": [
        "lib/queue/**/*.ts",
        "lib/db/**/*.ts",
        "lib/api/**/*.ts",
        "lib/ffmpeg/**/*.ts",
        "lib/gcs/**/*.ts",
        "lib/music/**/*.ts",
        "lib/utils/**/*.ts",
        "lib/inngest/**/*.ts",
        "types/**/*.ts",
        "emails/**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        ".next",
        "app",
        "components",
        "hooks"
    ]
}